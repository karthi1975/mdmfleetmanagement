# Database
DATABASE_URL=postgresql+asyncpg://fleet:fleet_secret@localhost:5433/fleet_db
DATABASE_URL_SYNC=postgresql+psycopg2://fleet:fleet_secret@localhost:5433/fleet_db
POSTGRES_DB=fleet_db
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet_secret

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Fleet Server
FLEET_HOST=0.0.0.0
FLEET_PORT=8000
LOG_LEVEL=DEBUG
SECRET_KEY=dev-secret-change-in-prod

# Storage
FIRMWARE_STORAGE_PATH=./data/firmware

# Absolute host path to project root (used by fleet-api to launch sibling
# esphome build containers via docker.sock). Set to project dir on host.
HOST_PROJECT_DIR=/opt/mdm_esp32
ESPHOME_IMAGE=esphome/esphome:2024.12.4

# Monitoring
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://loki:3100

# ESPHome Dashboard
ESPHOME_USERNAME=admin
ESPHOME_PASSWORD=change_me
