          "rawSql": "SELECT date_trunc('minute', started_at) as \"Started\",\n                  to_version as \"Target\",\n                  count(*) as \"Total\",\n                  sum(case when status='success' then 1 else 0 end) as \"Success\",\n                  sum(case when status='failed'  then 1 else 0 end) as \"Failed\",\n                  sum(case when status in ('pending','downloading','flashing') then 1 else 0 end) as \"In flight\"\n             FROM ota_events\n         GROUP BY date_trunc('minute', started_at), to_version\n         ORDER BY date_trunc('minute', started_at) DESC\n            LIMIT 30",
