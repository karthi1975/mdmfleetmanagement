          "rawSql": "SELECT id as \"ID\",\n                  fire_at as \"Fire at\",\n                  target_version as \"Target\",\n                  strategy as \"Strategy\",\n                  json_array_length(target_devices::json) as \"Devices\",\n                  status as \"Status\",\n                  fired_at as \"Fired at\",\n                  COALESCE(error,'') as \"Error\"\n             FROM scheduled_rollouts\n         ORDER BY fire_at DESC\n            LIMIT 30",
