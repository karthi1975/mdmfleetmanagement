          "rawSql": "SELECT g.id as \"ID\",\n                  g.name as \"Name\",\n                  COALESCE(g.description,'') as \"Description\",\n                  (SELECT count(*) FROM device_group_members m WHERE m.group_id = g.id) as \"Members\",\n                  g.created_by as \"Created by\",\n                  g.updated_at as \"Updated\"\n             FROM device_groups g\n         ORDER BY g.updated_at DESC",
